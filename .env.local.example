NEXT_PUBLIC_SUPABASE_URL=https://your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── WhatsApp ──────────────────────────────────────────────────────────────────
# Format: 628xxxxxxxxx (country code + number, no + or spaces)
NEXT_PUBLIC_WA_NUMBER=628xxxxxxxxx

# ─── Midtrans ─────────────────────────────────────────────────────────────────
# Set to "true" when moving to production Midtrans dashboard
# Get keys from: https://dashboard.midtrans.com (production)
#                 https://dashboard.sandbox.midtrans.com (sandbox)
MIDTRANS_IS_PRODUCTION=false

# Server key — NEVER expose to client / browser
MIDTRANS_SERVER_KEY=your-midtrans-server-key-here

# Client key — safe to expose via NEXT_PUBLIC_ prefix (used in browser Snap popup)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key-here

# Snap base URL — production: https://app.midtrans.com | sandbox: https://app.sandbox.midtrans.com
MIDTRANS_SNAP_BASE_URL=https://app.sandbox.midtrans.com
